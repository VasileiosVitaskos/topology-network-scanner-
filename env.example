# ══════════════════════════════════════════════════════════════
# TOPO-SCANNER v7 — Environment Configuration
# Netcompany Hackathon Thessaloniki 2026
# ══════════════════════════════════════════════════════════════
#
# Setup:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your secrets below
#   3. Never commit .env to git (it's in .gitignore)
#
# The app works WITHOUT an OpenAI key — Quick Scan falls back
# to rule-based analysis and the topological engine (Deep Scan)
# runs purely on math with zero external dependencies.
# ══════════════════════════════════════════════════════════════


# ── OpenAI (optional) ────────────────────────────────────────
# Powers: Quick Scan AI analysis, Chat Assistant
# Without it: rule-based fallback for Quick Scan, Chat disabled
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096


# ── Flask ────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Set to 1 for development, 0 for production/Docker
FLASK_DEBUG=0
# Change this to a random string in production
SECRET_KEY=change-me-to-a-random-string


# ── Database ─────────────────────────────────────────────────
# SQLite file location (volume-mounted in Docker)
# For local dev outside Docker, use a relative path:
#   DB_PATH=./db/topo_scanner.db
DB_PATH=/app/db/topo_scanner.db


# ── Dataset Directory ────────────────────────────────────────
# Where HAI, SWaT, BATADAL CSV files live
# For local dev outside Docker:
#   DATA_DIR=./data
DATA_DIR=/app/data


# ── Topological Engine ───────────────────────────────────────
# Default domain preset (see config/domains.yaml for all options)
# Options: water_treatment, power_grid, manufacturing, gas_pipeline, it_network
TOPO_DEFAULT_DOMAIN=water_treatment
# Max homology dimension (3 = compute up to β₃, higher = slower)
TOPO_MAX_DIMENSION=3


# ── Logging ──────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
